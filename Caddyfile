:{$PORT:80} {
    root * /srv
    encode gzip zstd

    # Try clean URLs (e.g. /about → about.html), then fall back to 404 page
    try_files {path} {path}.html {path}/index.html /404.html

    file_server
    header {
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        Cache-Control "public, max-age=3600"
    }
    # Long cache for fingerprinted static assets folder
    @assets path /assets/*
    header @assets Cache-Control "public, max-age=2592000, immutable"

    handle_errors {
        @404 expression `{err.status_code} == 404`
        rewrite @404 /404.html
        file_server
    }
}
